# pi-monitor-sudoers — Reference template
#
# Shows the sudoers rules that setup.sh generates.
# setup.sh writes the actual file to /etc/sudoers.d/pi-monitor-<username>
# with paths taken from FAN_CONTROL_BIN / GOV_CONTROL_BIN in backend/.env.
#
# You do NOT need to install this file manually.
# Run:  sudo setup/setup.sh <username>

# Replace placeholders with real values:
<username> ALL=(root) NOPASSWD: <GOV_CONTROL_BIN>
<username> ALL=(root) NOPASSWD: <FAN_CONTROL_BIN>
<username> ALL=(root) NOPASSWD: /usr/sbin/reboot

