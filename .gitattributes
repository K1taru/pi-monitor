# Force Unix (LF) line endings for shell scripts and config files
*.sh        text eol=lf
*.py        text eol=lf
*.env       text eol=lf
.env*       text eol=lf
Dockerfile  text eol=lf
*sudoers*   text eol=lf

# Windows-specific
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary files — no line ending conversion
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
