# Flask & JWT secrets — keep these private, never commit to git
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-your-own>
JWT_SECRET_KEY=<generate-your-own>

# Port the backend listens on — cloudflared or nginx should proxy to this
PORT=8001

# Comma-separated list of allowed CORS origins (no trailing slash)
CORS_ORIGINS=https://raspy.gymms.space,http://localhost:3000

# Default users created on first startup
# Format: username:password:is_admin;username2:password2:0
# is_admin: 1 = admin, 0 = regular user
# Passwords may contain spaces. Separate users with semicolons.
DEFAULT_USERS=yourname:yourpassword:1

# --- Path overrides (setup.sh reads these) ---
# Where the control scripts are installed as system binaries.
# Change if you want them somewhere other than /usr/local/bin/.
FAN_CONTROL_BIN=/usr/local/bin/pi-monitor-fan-control
GOV_CONTROL_BIN=/usr/local/bin/pi-monitor-gov-control

# Absolute path to the project root.
# setup.sh derives this from ~<username>/pi-monitor if not set here.
# Uncomment and change if you cloned elsewhere.
# PROJECT_DIR=/opt/pi-monitor

# Optional: custom database path (defaults to backend/raspy_monitor.db)
# DB_PATH=/var/lib/pi-monitor/raspy_monitor.db

# Flask debug mode — never enable on production
# FLASK_DEBUG=false
