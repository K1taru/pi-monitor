# /etc/sudoers.d/raspy-monitor
#
# Grants the k1taru user passwordless sudo for the operations
# required by the Raspy Monitor backend:
#   1. Setting CPU governor via the raspy-gov-control wrapper
#   2. Controlling the fan via the raspy-fan-control wrapper
#   3. Rebooting the system via the /api/system/reboot endpoint
#
# Install with:
#   sudo install -m 0755 deploy/gov-control.sh /usr/local/bin/raspy-gov-control
#   sudo install -m 0755 deploy/fan-control.sh /usr/local/bin/raspy-fan-control
#   sudo install -m 0440 deploy/raspy-monitor-sudoers /etc/sudoers.d/raspy-monitor
#   sudo visudo -c   # verify no syntax errors

k1taru ALL=(root) NOPASSWD: /usr/local/bin/raspy-gov-control
k1taru ALL=(root) NOPASSWD: /usr/local/bin/raspy-fan-control
k1taru ALL=(root) NOPASSWD: /usr/sbin/reboot
k1taru ALL=(root) NOPASSWD: /usr/sbin/reboot
